# ============================================================
# Deal Bot v3.0 — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ---- Cuelinks Affiliate ----
# Get from: https://publisher.cuelinks.com -> API Keys
# NOTE: Not required — bot works without it using direct tracking links.
# Set this to get proper cuelinks.com affiliate links for better commissions.
CUELINKS_API_KEY=your_cuelinks_api_key_here
CUELINKS_PUBLISHER_ID=your_publisher_id_here
CUELINKS_CHANNEL_ID=your_channel_id_here

# ---- Telegram (REQUIRED for broadcasting) ----
# Create a bot via @BotFather on Telegram, get token
TELEGRAM_BOT_TOKEN=
# Your channel/group ID (e.g. -100xxxxxxxxxx for channels, or @myusername)
TELEGRAM_CHAT_ID=
# Channel username WITHOUT @ (used in sharing links)
TELEGRAM_CHANNEL_USERNAME=
# Public invite link to your channel
TELEGRAM_CHANNEL_INVITE_LINK=

# ---- Bot Mode ----
# "oneshot" = run once and exit (for GitHub Actions)
# "server"  = keep running with webhook handler (for Replit/VPS)
BOT_MODE=oneshot

# ---- Run Interval (server mode only) ----
RUN_INTERVAL_MINUTES=60

# ---- Deal Sources ----
DEALS_FILE=./data/deals.json

# ---- Output ----
OUTPUT_DIR=./deals
IMAGE_DIR=./deals/images

# ---- Logging ----
LOG_LEVEL=info

# ---- Deal Quality Filters ----
MIN_DISCOUNT_PERCENT=20
MIN_SAVINGS_AMOUNT=200
MIN_RATING=3.5
MAX_DEALS_PER_RUN=15
BLOCKED_KEYWORDS=refurbished,renewed,used
ALLOWED_DEAL_DOMAINS=amazon.,flipkart.,myntra.,ajio.,nykaa.,tatacliq.,croma.,reliancedigital.,meesho.,snapdeal.,desidime.com,mydala.com,grabon.in
REJECT_NEWS_CONTENT=true
PROCESSED_DEAL_TTL_HOURS=24

# ---- Affiliate Strictness ----
# false = post all deals even without Cuelinks approval (RECOMMENDED while growing)
# true  = only post deals that get a cuelinks.com link
STRICT_AFFILIATE_ONLY=false

# ---- Distribution Webhooks (optional) ----
# Comma-separated webhook URLs (Zapier/Make/custom)
DISTRIBUTION_WEBHOOKS=

# ---- Twitter (optional, stubbed) ----
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ---- Email (optional, stubbed) ----
EMAIL_USER=
EMAIL_PASS=
EMAIL_TO=
