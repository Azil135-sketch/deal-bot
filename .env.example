# ================================================================
  # DEAL-BOT ENVIRONMENT CONFIGURATION
  # Copy this file to .env and fill in your actual values.
  # Never commit .env to version control.
  # ================================================================

  # ---- CUELINKS AFFILIATE (optional but recommended) ----
  # Sign up at https://www.cuelinks.com
  # Supports Nykaa, Myntra, Ajio, TataCliq + 4000+ Indian stores
  # NOTE: Meesho is NOT available in Cuelinks
  CUELINKS_API_KEY=
  CUELINKS_PUBLISHER_ID=
  CUELINKS_CHANNEL_ID=

  # ---- TELEGRAM (required) ----
  # Create bot via @BotFather, make it admin of your channel
  # TELEGRAM_CHAT_ID supports multiple channels: -100123456,-100789012
  TELEGRAM_BOT_TOKEN=
  TELEGRAM_CHAT_ID=
  TELEGRAM_CHANNEL_USERNAME=@your_channel
  TELEGRAM_CHANNEL_INVITE_LINK=https://t.me/your_channel

  # ---- REDDIT (optional — free organic reach to 60K+ r/DesiDeal members) ----
  # Create Reddit app: https://www.reddit.com/prefs/apps -> script type
  REDDIT_CLIENT_ID=
  REDDIT_CLIENT_SECRET=
  REDDIT_USERNAME=
  REDDIT_PASSWORD=

  # ---- DISCORD (optional — rich embed posts via webhook) ----
  # Channel Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
  # Multiple webhooks (comma-separated): url1,url2
  DISCORD_WEBHOOK_URL=

  # ---- GITHUB PAGES DEAL SITE (optional — free SEO traffic) ----
  # In GitHub Actions this is auto-filled via github.token and github.repository
  # Locally: use a Personal Access Token with repo write access
  # Enable Pages: Repo Settings -> Pages -> Branch: gh-pages -> / (root)
  GITHUB_TOKEN=
  GITHUB_REPO=Azil135-sketch/deal-bot

  # ---- ZAPIER/MAKE WEBHOOKS (optional) ----
  DISTRIBUTION_WEBHOOKS=

  # ---- DEAL QUALITY FILTERS ----
  MIN_DISCOUNT_PERCENT=20
  MIN_SAVINGS_AMOUNT=200
  MIN_RATING=3.5
  MAX_DEALS_PER_RUN=10

  # ---- DEAL SOURCES ----
  DEALS_FILE=./data/deals.json
  STRICT_AFFILIATE_ONLY=false
  FETCH_PRODUCT_IMAGES=true

  # ---- PROCESSING ----
  PROCESSED_DEAL_TTL_HOURS=12
  OUTPUT_DIR=./deals
  LOG_LEVEL=info
  BOT_MODE=oneshot
  NODE_ENV=production
  