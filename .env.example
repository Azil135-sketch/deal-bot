# === TELEGRAM (Required) ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_CHANNEL_USERNAME=yourchannelname
TELEGRAM_CHANNEL_INVITE_LINK=https://t.me/+xxxxxxxxxxxxxxxx

# === CUELINKS AFFILIATE (Optional — auto-approved stores work instantly) ===
CUELINKS_API_KEY=your_cuelinks_api_key
CUELINKS_PUBLISHER_ID=your_publisher_id
CUELINKS_CHANNEL_ID=your_channel_id

# === REDDIT (Optional — auto-posts to deal subreddits) ===
REDDIT_CLIENT_ID=your_client_id
REDDIT_CLIENT_SECRET=your_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# === DISCORD (Optional — multi-server webhook posting) ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# === TWITTER/X (Optional — requires twitter-api-v2 package) ===
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret

# === DIRECT AFFILIATE PROGRAMS (Optional — if you have accounts) ===
# Amazon Associates: https://affiliate-program.amazon.in/
AMAZON_ASSOCIATES_TAG=yourstore-21
# Flipkart Affiliate: https://affiliate.flipkart.com/
FLIPKART_AFFILIATE_ID=your_flipkart_id

# === DISTRIBUTION NETWORK (Optional) ===
# Comma-separated list of Telegram community handles for cross-posting
TARGET_COMMUNITIES=@dealsgroup1,@dealsgroup2

# === CONFIG ===
DEALS_FILE=./data/deals.json
MIN_DISCOUNT_PERCENT=15
MIN_SAVINGS_AMOUNT=100
MAX_DEALS_PER_RUN=8
FETCH_PRODUCT_IMAGES=true
CHECK_STOCK=true
MIN_QUALITY_SCORE=22
PROCESSED_DEAL_TTL_HOURS=20
LOG_LEVEL=info
BOT_MODE=oneshot
