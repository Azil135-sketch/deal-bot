# =============================================
  # Deal Bot v3.0 — Environment Configuration
  # Copy this file to .env and fill in your values
  # =============================================

  # ---- Cuelinks Affiliate Network ----
  # Register at: https://publisher.cuelinks.com
  # Amazon & Flipkart require campaign approval for new publishers.
  # Nykaa, Myntra, Ajio, TataCliq typically approve faster.
  # Meesho does NOT have a Cuelinks campaign — UTM tags used instead.
  # The bot works without these (uses direct tracking params as fallback).
  CUELINKS_API_KEY=
  CUELINKS_PUBLISHER_ID=
  CUELINKS_CHANNEL_ID=

  # ---- Telegram Bot ----
  # Required for broadcasting deals to your channel.
  # 1. Create a bot at @BotFather, get TELEGRAM_BOT_TOKEN
  # 2. Add the bot as admin to your channel
  # 3. Get your channel ID (e.g. -1001234567890) for TELEGRAM_CHAT_ID
  # 4. Get your channel @username for TELEGRAM_CHANNEL_USERNAME
  TELEGRAM_BOT_TOKEN=
  TELEGRAM_CHAT_ID=
  TELEGRAM_CHANNEL_USERNAME=
  TELEGRAM_CHANNEL_INVITE_LINK=

  # ---- Deal Sources ----
  # Path to hand-curated deals JSON file (optional — scrapers run regardless)
  DEALS_FILE=./data/deals.json

  # ---- Output Directories ----
  OUTPUT_DIR=./deals
  IMAGE_DIR=./deals/images

  # ---- Logging ----
  LOG_LEVEL=info

  # ---- Deal Quality Filters ----
  MIN_DISCOUNT_PERCENT=20
  MIN_SAVINGS_AMOUNT=200
  MIN_RATING=3.5
  MAX_DEALS_PER_RUN=15
  BLOCKED_KEYWORDS=refurbished,renewed,used
  # Domains allowed for deal URLs — scraper sites (desidime, grabon, coupondunia) are included
  ALLOWED_DEAL_DOMAINS=amazon.,flipkart.,myntra.,ajio.,nykaa.,tatacliq.,croma.,reliancedigital.,meesho.,snapdeal.,desidime.com,grabon.in,coupondunia.in
  REJECT_NEWS_CONTENT=true
  # How many hours before the same deal can be re-posted (0 = always re-post)
  PROCESSED_DEAL_TTL_HOURS=24

  # ---- Affiliate Strictness ----
  # false (recommended) = post all deals even without Cuelinks approval
  # true = only post deals that get a real cuelinks.com affiliate link
  STRICT_AFFILIATE_ONLY=false

  # ---- Bot Mode ----
  # oneshot = run once and exit (GitHub Actions default)
  # server  = run on interval with webhook server (Replit/VPS)
  BOT_MODE=oneshot
  RUN_INTERVAL_MINUTES=60

  # ---- Distribution Webhooks (optional) ----
  # Comma-separated Zapier/Make webhook URLs to also push deal payloads to
  DISTRIBUTION_WEBHOOKS=

  # ---- Twitter (optional, not yet implemented) ----
  TWITTER_API_KEY=
  TWITTER_API_SECRET=
  TWITTER_ACCESS_TOKEN=
  TWITTER_ACCESS_TOKEN_SECRET=

  # ---- Email (optional, not yet implemented) ----
  EMAIL_USER=
  EMAIL_PASS=
  EMAIL_TO=
  