# Cuelinks API Configuration
CUELINKS_API_KEY=your_cuelinks_api_key_here
CUELINKS_PUBLISHER_ID=your_publisher_id_here
CUELINKS_CHANNEL_ID=your_channel_id_here

# Deal Sources
DEAL_SOURCES=amazon,flipkart,myntra

# Output Configuration
OUTPUT_DIR=./deals
IMAGE_DIR=./deals/images

# Logging
LOG_LEVEL=info

# Optional data source and automation
DEALS_FILE=./data/deals.json
RUN_INTERVAL_MINUTES=0
MAX_DEALS_PER_RUN=20
PROCESSED_DEAL_TTL_HOURS=24

# Deal Intelligence (quality floors)
MIN_DISCOUNT_PERCENT=20
MIN_SAVINGS_AMOUNT=300
MIN_RATING=3.8
BLOCKED_KEYWORDS=refurbished,renewed,used
STRICT_AFFILIATE_ONLY=true
ALLOWED_DEAL_DOMAINS=amazon.,flipkart.,myntra.,ajio.,nykaa.,tatacliq.,croma.,reliancedigital.,meesho.,snapdeal.
REJECT_NEWS_CONTENT=true

# Distribution channels
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISTRIBUTION_WEBHOOKS=
